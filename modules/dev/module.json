  "displayName": "General Software Development",
  "description": "Développement logiciel général : agents developer, architect, code-reviewer, qa-engineer, doc-writer, analyst. Workflows feature-dev, code-review, refactor, repo-context. Outils scaffold, test-gen, create-docs.",
  "version": "1.0.0",
  "depends": ["core", "process"],
  "components": {
    "agents": [
      ".claude/agents/developer.md",
      ".claude/agents/architect.md",
      ".claude/agents/code-reviewer.md",
      ".claude/agents/qa-engineer.md",
      ".claude/agents/doc-writer.md",
      ".claude/agents/analyst.md"
    ],
    "workflows": [
      ".claude/commands/workflows/feature-dev.md",
      ".claude/commands/workflows/code-review.md",
      ".claude/commands/workflows/refactor.md",
      ".claude/commands/workflows/full-context.md",
      ".claude/commands/workflows/new-project-setup.md",
      ".claude/commands/workflows/repo-context.md",
      ".claude/commands/workflows/verify-goal.md"
    ],
    "tools": [
      ".claude/commands/tools/scaffold.md",
      ".claude/commands/tools/test-gen.md",
      ".claude/commands/tools/create-docs.md",
      ".claude/commands/tools/update-docs.md"
    ]
